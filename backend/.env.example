# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/leave_management

# JWT
JWT_SECRET=replace_with_a_strong_32_plus_byte_secret
JWT_EXPIRE=7d
JWT_ISSUER=leave-ms-api
JWT_AUDIENCE=leave-ms-web

# CORS / Frontend
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Zoho SMTP (use smtp.zoho.in for India region accounts)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=info@aceitup.in
SMTP_PASS=YOUR_ZOHO_APP_PASSWORD
SMTP_FROM="ACE IT UP" <info@aceitup.in>
ADMIN_EMAIL=info@aceitup.in
